<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Suvam Paul | Portfolio</title>
  <meta name="description" content="Suvam Paul portfolio featuring AI-powered, full-stack, and health-tech projects from GitHub, with direct GitHub and LinkedIn links." />
  <style>
    :root{
      --bg:#070A12;
      --bg2:#0B1020;
      --card:rgba(255,255,255,.06);
      --card2:rgba(255,255,255,.09);
      --text:#EAF0FF;
      --muted:#A9B4D0;
      --line:rgba(255,255,255,.12);
      --accent:#7C5CFF;
      --accent2:#18D5FF;
      --accent3:#00E6A8;
      --shadow:0 18px 60px rgba(0,0,0,.35);
      --radius:24px;
      --radius2:32px;
      --max:1180px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 20% 20%, rgba(124,92,255,.20), transparent 28%),
        radial-gradient(circle at 80% 10%, rgba(24,213,255,.14), transparent 22%),
        radial-gradient(circle at 70% 70%, rgba(0,230,168,.10), transparent 20%),
        linear-gradient(180deg, var(--bg), var(--bg2));
      overflow-x:hidden;
    }

    a{color:inherit; text-decoration:none}
    img{max-width:100%; display:block}
    .container{width:min(100% - 32px, var(--max)); margin-inline:auto}
    .glass{
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.04));
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      backdrop-filter: blur(18px);
    }
    .pill{
      display:inline-flex; align-items:center; gap:.55rem;
      padding:.65rem 1rem;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.04);
      color:var(--muted);
      font-size:.92rem;
    }
    .dot{width:10px;height:10px;border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2))}
    .btn{
      display:inline-flex; align-items:center; justify-content:center; gap:.55rem;
      padding:1rem 1.25rem;
      border-radius:999px;
      border:1px solid transparent;
      font-weight:700;
      transition:.25s ease;
      cursor:pointer;
      user-select:none;
    }
    .btn-primary{
      background:linear-gradient(135deg, var(--accent), var(--accent2));
      color:#08101E;
      box-shadow:0 12px 34px rgba(124,92,255,.25);
    }
    .btn-primary:hover{transform:translateY(-2px); filter:saturate(1.1)}
    .btn-ghost{
      background:rgba(255,255,255,.04);
      border-color:var(--line);
      color:var(--text);
    }
    .btn-ghost:hover{background:rgba(255,255,255,.08)}
    .section{padding:92px 0}
    .section-head{
      display:flex; align-items:end; justify-content:space-between; gap:24px;
      margin-bottom:28px;
    }
    .section-head h2{
      margin:0;
      font-size:clamp(1.6rem, 3vw, 2.6rem);
      letter-spacing:-.04em;
    }
    .section-head p{margin:0; color:var(--muted); max-width:680px; line-height:1.7}
    .grid{display:grid; gap:18px}

    header{
      position:sticky; top:0; z-index:1000;
      border-bottom:1px solid rgba(255,255,255,.06);
      background:rgba(7,10,18,.62);
      backdrop-filter: blur(18px);
    }
    .nav{
      height:78px;
      display:flex; align-items:center; justify-content:space-between; gap:18px;
    }
    .brand{
      display:flex; align-items:center; gap:12px;
      font-weight:800;
      letter-spacing:-.03em;
    }
    .brand-mark{
      width:40px;height:40px;border-radius:14px;
      display:grid;place-items:center;
      background:linear-gradient(135deg, var(--accent), var(--accent2));
      color:#08101E;
      box-shadow:0 10px 25px rgba(24,213,255,.18);
    }
    .nav-links{
      display:flex; align-items:center; gap:22px;
      color:var(--muted);
      font-weight:600;
    }
    .nav-links a{position:relative; padding:.35rem 0}
    .nav-links a::after{
      content:""; position:absolute; left:0; bottom:-5px;
      width:100%; height:2px; border-radius:999px;
      transform:scaleX(0); transform-origin:left;
      background:linear-gradient(135deg, var(--accent), var(--accent2));
      transition:.22s ease;
    }
    .nav-links a:hover::after, .nav-links a.active::after{transform:scaleX(1)}
    .menu-btn{
      display:none;
      width:46px; height:46px; border-radius:14px;
      border:1px solid var(--line); background:rgba(255,255,255,.04);
      color:var(--text);
      cursor:pointer;
    }

    .hero{
      padding:72px 0 20px;
      position:relative;
    }
    .hero-wrap{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:24px;
      align-items:center;
      min-height:calc(100vh - 90px);
    }
    .hero-copy{padding:24px 0}
    .eyebrow{margin-bottom:16px}
    .hero h1{
      margin:0;
      font-size:clamp(2.6rem, 7vw, 5.6rem);
      line-height:.96;
      letter-spacing:-.06em;
      max-width:12ch;
    }
    .gradient{
      background:linear-gradient(135deg, #fff 0%, #B2C6FF 30%, #7C5CFF 70%, #18D5FF 100%);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .hero p{
      color:var(--muted);
      max-width:62ch;
      font-size:1.06rem;
      line-height:1.8;
      margin:18px 0 28px;
    }
    .hero-actions{display:flex; flex-wrap:wrap; gap:12px; margin-bottom:22px}
    .hero-stats{
      display:grid; grid-template-columns:repeat(3, minmax(0,1fr));
      gap:12px; margin-top:20px;
    }
    .stat{
      padding:16px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
    }
    .stat strong{display:block; font-size:1.3rem; margin-bottom:6px}
    .stat span{color:var(--muted); font-size:.92rem}

    .hero-card{
      position:relative;
      min-height:640px;
      padding:22px;
      border-radius:var(--radius2);
      overflow:hidden;
    }
    .hero-card::before{
      content:"";
      position:absolute; inset:-2px;
      background:
        radial-gradient(circle at 20% 20%, rgba(124,92,255,.35), transparent 22%),
        radial-gradient(circle at 80% 20%, rgba(24,213,255,.24), transparent 18%),
        radial-gradient(circle at 50% 80%, rgba(0,230,168,.16), transparent 20%);
      filter: blur(12px);
      opacity:.9;
      pointer-events:none;
    }
    .profile{
      position:relative;
      height:100%;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:18px;
    }
    .profile-top, .profile-bottom{
      display:grid;
      gap:16px;
    }
    .avatar{
      width:88px; height:88px; border-radius:28px;
      display:grid; place-items:center;
      background:linear-gradient(135deg, rgba(124,92,255,.9), rgba(24,213,255,.85));
      font-size:2rem;
      font-weight:900;
      color:#08101E;
      box-shadow:0 16px 35px rgba(124,92,255,.2);
    }
    .profile-box{
      padding:18px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(4,7,14,.45);
    }
    .profile-box h3, .profile-box p{margin:0}
    .profile-box p{color:var(--muted); line-height:1.7; margin-top:8px}
    .mini-badges{display:flex; flex-wrap:wrap; gap:10px}
    .mini-badges span{
      padding:.55rem .8rem;
      border-radius:999px;
      font-size:.85rem;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--muted);
    }

    .orb{
      position:absolute; border-radius:50%;
      filter: blur(18px);
      opacity:.28;
      animation: float 10s ease-in-out infinite;
    }
    .orb.one{width:160px;height:160px; right:28px; top:32px; background:var(--accent)}
    .orb.two{width:220px;height:220px; left:-30px; bottom:70px; background:var(--accent2); animation-delay:-2.4s}
    .orb.three{width:120px;height:120px; right:120px; bottom:160px; background:var(--accent3); animation-delay:-4.6s}
    @keyframes float{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-18px) translateX(12px)}
    }

    .chips{display:flex; flex-wrap:wrap; gap:10px; margin-top:8px}
    .chip{
      padding:.65rem .9rem; border-radius:999px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--muted);
      font-size:.9rem;
    }

    .cards-3{grid-template-columns:repeat(3, minmax(0,1fr))}
    .cards-2{grid-template-columns:repeat(2, minmax(0,1fr))}
    .card{
      padding:22px;
      border-radius:var(--radius);
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      box-shadow:var(--shadow);
      transition:.25s ease;
      position:relative;
      overflow:hidden;
    }
    .card:hover{transform:translateY(-4px); border-color:rgba(124,92,255,.35)}
    .card .icon{
      width:48px;height:48px;border-radius:16px;
      display:grid;place-items:center;
      background:linear-gradient(135deg, rgba(124,92,255,.16), rgba(24,213,255,.12));
      border:1px solid var(--line);
      margin-bottom:14px;
      font-size:1.2rem;
    }
    .card h3{margin:0 0 10px; font-size:1.15rem}
    .card p{margin:0; color:var(--muted); line-height:1.75}
    .tag-row{display:flex; flex-wrap:wrap; gap:8px; margin-top:16px}
    .tag-row span{
      font-size:.82rem;
      padding:.45rem .7rem;
      border-radius:999px;
      color:#dfe8ff;
      background:rgba(255,255,255,.05);
      border:1px solid var(--line);
    }

    .project-grid{grid-template-columns:repeat(auto-fit, minmax(280px,1fr))}
    .project{
      padding:0;
      overflow:hidden;
    }
    .project-top{
      padding:22px 22px 0;
    }
    .project-top h3{margin-bottom:10px}
    .project-media{
      margin-top:18px;
      height:220px;
      border-top:1px solid var(--line);
      background:
        radial-gradient(circle at 20% 35%, rgba(124,92,255,.25), transparent 28%),
        radial-gradient(circle at 80% 30%, rgba(24,213,255,.22), transparent 24%),
        linear-gradient(135deg, rgba(255,255,255,.03), rgba(255,255,255,.08));
      position:relative;
      overflow:hidden;
    }
    .project-media::before, .project-media::after{
      content:"";
      position:absolute;
      inset:auto;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(8px);
    }
    .project-media::before{
      width:72%; height:34px; left:14%; top:24px;
    }
    .project-media::after{
      width:44%; height:120px; left:10%; bottom:24px;
    }
    .project-meta{
      display:flex; justify-content:space-between; gap:12px;
      padding:18px 22px 22px;
      align-items:center;
      flex-wrap:wrap;
    }
    .project-meta small{color:var(--muted)}
    .project-links{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }
    .project-links a{
      padding:.75rem 1rem;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
    }

    .timeline{
      position:relative;
      padding-left:20px;
    }
    .timeline::before{
      content:""; position:absolute; left:7px; top:10px; bottom:10px;
      width:2px; background:linear-gradient(180deg, var(--accent), var(--accent2));
      opacity:.55;
    }
    .step{
      position:relative;
      margin-bottom:18px;
      padding:18px 18px 18px 22px;
      border-radius:20px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
    }
    .step::before{
      content:""; position:absolute; left:-24px; top:24px;
      width:14px; height:14px; border-radius:50%;
      background:linear-gradient(135deg, var(--accent), var(--accent2));
      box-shadow:0 0 0 6px rgba(124,92,255,.12);
    }
    .step h4{margin:0 0 8px}
    .step p{margin:0; color:var(--muted); line-height:1.7}

    .contact{
      display:grid;
      grid-template-columns:.95fr 1.05fr;
      gap:18px;
      align-items:start;
    }
    form{
      display:grid;
      gap:14px;
    }
    .field{
      display:grid;
      gap:8px;
    }
    label{font-weight:700; color:#dfe8ff; font-size:.93rem}
    input, textarea{
      width:100%;
      padding:1rem 1.05rem;
      border-radius:18px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--text);
      outline:none;
      font:inherit;
      resize:vertical;
    }
    input::placeholder, textarea::placeholder{color:#8d97b3}
    input:focus, textarea:focus{border-color:rgba(24,213,255,.45); box-shadow:0 0 0 4px rgba(24,213,255,.10)}
    .contact-links{
      display:grid;
      gap:12px;
      margin-top:14px;
    }
    .contact-link{
      padding:1rem 1.05rem;
      border-radius:18px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    }
    .contact-link span{color:var(--muted)}
    footer{
      padding:26px 0 40px;
      color:var(--muted);
      border-top:1px solid rgba(255,255,255,.08);
      margin-top:28px;
    }
    .footer-row{
      display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap;
      align-items:center;
    }

    .reveal{opacity:0; transform:translateY(18px); transition:.6s ease}
    .reveal.show{opacity:1; transform:translateY(0)}

    @media (max-width: 980px){
      .hero-wrap, .contact, .project-grid, .cards-3, .cards-2{grid-template-columns:1fr}
      .hero-card{min-height:520px}
      .section{padding:78px 0}
      .section-head{align-items:start; flex-direction:column}
      .hero h1{max-width:14ch}
    }
    @media (max-width: 760px){
      .nav-links{
        position:fixed;
        top:78px; left:16px; right:16px;
        display:grid;
        gap:0;
        padding:12px;
        border-radius:24px;
        background:rgba(7,10,18,.92);
        border:1px solid var(--line);
        transform:translateY(-14px);
        opacity:0; pointer-events:none;
        transition:.2s ease;
      }
      .nav-links.open{transform:translateY(0); opacity:1; pointer-events:auto}
      .nav-links a{
        padding:14px 12px;
        border-radius:14px;
      }
      .nav-links a:hover{background:rgba(255,255,255,.05)}
      .menu-btn{display:inline-grid; place-items:center}
      .hero{padding-top:48px}
      .hero-stats{grid-template-columns:1fr}
      .hero h1{font-size:clamp(2.4rem, 13vw, 4.6rem)}
      .project-media{height:180px}
    }
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <a href="#home" class="brand">
        <div class="brand-mark">SP</div>
        <div>
          <div>Suvam Paul</div>
          <small style="color:var(--muted); font-weight:600;">AI • Full Stack • Open Source</small>
        </div>
      </a>

      <nav class="nav-links" id="navLinks">
        <a href="#home" class="active">Home</a>
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#opensource">Open Source</a>
        <a href="#contact">Contact</a>
      </nav>

      <button class="menu-btn" id="menuBtn" aria-label="Open menu">☰</button>
    </div>
  </header>

  <main id="home" class="hero">
    <div class="container hero-wrap">
      <section class="hero-copy reveal">
        <div class="pill eyebrow"><span class="dot"></span> AI-powered builder shipping full-stack products</div>
        <h1>Building <span class="gradient">intelligent systems</span> with product focus.</h1>
        <p>
          I am Suvam Paul, a CSE student building AI-integrated web products across healthcare, developer
          tooling, analytics, and productivity. My work blends modern frontend execution with backend
          architecture, cloud services, and practical problem-solving.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="#projects">View featured projects</a>
          <a class="btn btn-ghost" href="https://github.com/Suvam-paul145" target="_blank" rel="noreferrer">GitHub profile</a>
        </div>

        <div class="chips" aria-label="Highlights">
          <span class="chip">AI Products</span>
          <span class="chip">Full-Stack Systems</span>
          <span class="chip">AWS + Cloud</span>
          <span class="chip">Healthcare Tech</span>
          <span class="chip">Open Source</span>
        </div>

        <div class="hero-stats">
          <div class="stat glass">
            <strong>79+</strong>
            <span>Public repositories on GitHub</span>
          </div>
          <div class="stat glass">
            <strong>AI + Web</strong>
            <span>Production-minded apps with real use cases</span>
          </div>
          <div class="stat glass">
            <strong>Builder</strong>
            <span>Open source, hackathons, and shipping fast</span>
          </div>
        </div>
      </section>

      <aside class="hero-card glass reveal">
        <div class="orb one"></div>
        <div class="orb two"></div>
        <div class="orb three"></div>

        <div class="profile">
          <div class="profile-top">
            <div class="avatar">SP</div>
            <div class="profile-box">
              <h3>About me</h3>
              <p>
                I am growing into an AI-powered backend full-stack engineer, with strong interest in
                authentication, intelligent workflows, cloud deployment, and interfaces that feel polished.
              </p>
            </div>
            <div class="profile-box">
              <h3>What I am building now</h3>
              <p>
                Current GitHub work spans medical communication tools, analytics assistants, AI coding tutors,
                developer OS automation, and productivity systems with smart reminders.
              </p>
            </div>
          </div>

          <div class="profile-bottom">
            <div class="mini-badges">
              <span>Web Developer</span>
              <span>AWS</span>
              <span>Machine Learning</span>
              <span>Developer Program Member</span>
            </div>
            <div class="profile-box">
              <h3>LinkedIn</h3>
              <p><a href="https://www.linkedin.com/in/suvam-paul-03222005az/" target="_blank" rel="noreferrer">linkedin.com/in/suvam-paul-03222005az</a></p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <section id="about" class="section">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <h2>About & strengths</h2>
          <p>
            The strongest pattern across your public work is clear: you like products that combine AI,
            practical UX, backend logic, and visible real-world value.
          </p>
        </div>
      </div>

      <div class="grid cards-3">
        <article class="card reveal">
          <div class="icon">⚡</div>
          <h3>AI-integrated product building</h3>
          <p>I build apps where the UI is only one layer of the product, backed by automation, LLM workflows, and task-driven systems.</p>
          <div class="tag-row">
            <span>LLMs</span><span>FastAPI</span><span>React</span><span>Automation</span>
          </div>
        </article>

        <article class="card reveal">
          <div class="icon">🎨</div>
          <h3>Full-stack engineering mindset</h3>
          <p>Your repositories show comfort with frontend apps, APIs, databases, auth flows, dashboards, and deployment-ready architecture.</p>
          <div class="tag-row">
            <span>TypeScript</span><span>Node.js</span><span>Python</span><span>MongoDB</span>
          </div>
        </article>

        <article class="card reveal">
          <div class="icon">🚀</div>
          <h3>Cloud and launch readiness</h3>
          <p>Several projects already ship with live demos, cloud services, or deployment targets across Vercel, AWS, and similar tooling.</p>
          <div class="tag-row">
            <span>AWS</span><span>Vercel</span><span>Render</span><span>Open Source</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="projects" class="section">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <h2>Featured GitHub projects</h2>
          <p>
            These were selected from your public GitHub profile using a mix of visibility, originality,
            activity, and how well they represent your strongest work.
          </p>
        </div>
      </div>

      <div class="grid project-grid">
        <article class="card project reveal">
          <div class="project-top">
            <h3>SwasthaLink</h3>
            <p>
              A full-stack medical communication platform that converts discharge summaries into plain,
              bilingual explanations and delivers them through patient-friendly workflows.
            </p>
            <div class="tag-row">
              <span>Healthcare AI</span><span>FastAPI</span><span>React</span><span>WhatsApp</span>
            </div>
          </div>
          <div class="project-media"></div>
          <div class="project-meta">
            <small>Top public repo by stars, forks, and current activity</small>
            <div class="project-links">
              <a href="https://github.com/Suvam-paul145/SwasthaLink" target="_blank" rel="noreferrer">GitHub</a>
              <a href="https://swastha-link-psi.vercel.app" target="_blank" rel="noreferrer">Live demo</a>
            </div>
          </div>
        </article>

        <article class="card project reveal">
          <div class="project-top">
            <h3>DEV.OS</h3>
            <p>
              An AI-powered operating system assistant that connects a modern interface, backend orchestration,
              Gemini-powered reasoning, and local OS automation.
            </p>
            <div class="tag-row">
              <span>AI Assistant</span><span>TypeScript</span><span>Python</span><span>Microservices</span>
            </div>
          </div>
          <div class="project-media"></div>
          <div class="project-meta">
            <small>One of your strongest concept-to-system builds</small>
            <div class="project-links">
              <a href="https://github.com/Suvam-paul145/Dev-AI-OS-assistant" target="_blank" rel="noreferrer">GitHub</a>
            </div>
          </div>
        </article>

        <article class="card project reveal">
          <div class="project-top">
            <h3>KaryaSetu</h3>
            <p>
